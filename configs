        novedadesSistema: "Novedades del sistema", enterate: "Enterarte de funciones o cambios nuevos.",
        privacidad: "Privacidad", definePerfil: "Define cómo te muestras en la plataforma.",
        mostrarEstado: "Mostrar estado", permitirVer: "Permitir que otros vean si estás activo.",
        perfilPublico: "Perfil público", visibleOtros: "Visible para otros usuarios dentro de UniMarket.",
        cuenta: "Cuenta", datosCuenta: "Datos generales de la cuenta y acciones rápidas.",
        usuarioActual: "Usuario actual", invitado: "Invitado", correo: "Correo", sinCorreo: "Sin correo vinculado",
        cambiarUsuario: "Cambiar usuario", cambiarContraseña: "Cambiar contraseña",
        nuevoUsuarioPrompt: "Nuevo nombre de usuario:",
        usuarioActualizado: "Usuario actualizado",
        passActual: "Contraseña actual",
        nuevaPass: "Nueva contraseña",
        confirmarNuevaPass: "Confirmar nueva contraseña",
        ingresaDatos: "Ingresa tus credenciales para actualizar.",
        completarCampos: "Completa todos los campos",
        passNoCoinciden: "Las nuevas contraseñas no coinciden",
        passActualizada: "Contraseña actualizada correctamente",
        ingresaNuevoUsuario: "Ingresa tu nuevo nombre de usuario.",
        nuevoUsuario: "Nuevo nombre de usuario",
        error: "Error",
        errorConexion: "Error de conexión",
        passCorta: "La nueva contraseña debe tener al menos 4 caracteres"
      },
      en: {
        inicio: "Home", perfil: "Profile", mensajes: "Messages", notificaciones: "Notifications",
        configuraciones: "Settings", cerrarSesion: "Log out",
        preferencias: "UniMarket Preferences", tituloConfig: "Settings",
        apariencia: "Appearance", personaliza: "Customize how UniMarket looks.",
        modoOscuro: "Dark mode", activaTema: "Enable or disable the system dark theme.",
        idioma: "Language", seleccionaIdioma: "Select the interface language.",
        tamanoTexto: "Text size", ajustarTexto: "Adjust the text size across the platform.",
        pequeno: "Small", normal: "Normal", grande: "Large",
        comentarios: "Comments", alertaComentarios: "Receive alerts when someone comments on your posts.",
        mostrarAvisos: "Show alerts when you receive a new message.",
        novedadesSistema: "System news", enterate: "Find out about new features or changes.",
        privacidad: "Privacy", definePerfil: "Define how you appear on the platform.",
        mostrarEstado: "Show status", permitirVer: "Allow others to see if you're active.",
        perfilPublico: "Public profile", visibleOtros: "Visible to other users within UniMarket.",
        cuenta: "Account", datosCuenta: "General account data and quick actions.",
        usuarioActual: "Current user", invitado: "Guest", correo: "Email", sinCorreo: "No email linked",
        cambiarUsuario: "Change username", cambiarContraseña: "Change password",
        nuevoUsuarioPrompt: "New username:",
        usuarioActualizado: "Username updated",
        passActual: "Current password",
        nuevaPass: "New password",
        confirmarNuevaPass: "Confirm new password",
        ingresaDatos: "Enter your credentials to update.",
        completarCampos: "Please fill all fields",
        passNoCoinciden: "New passwords do not match",
        passActualizada: "Password updated successfully",
        ingresaNuevoUsuario: "Enter your new username.",
        nuevoUsuario: "New username",
        error: "Error",
        errorConexion: "Connection error",
        passCorta: "The new password must be at least 4 characters"
      }
    };

    function getLang() { return localStorage.getItem("lang") || "es"; }
    function tConfig(key) { return (translationsConfig[getLang()] && translationsConfig[getLang()][key]) || key; }

    function aplicarIdiomaConfig() {
      const lang = getLang();
      document.querySelectorAll("[data-i18n]").forEach(el => {
        const key = el.dataset.i18n;
        if (translationsConfig[lang] && translationsConfig[lang][key]) {
          el.textContent = translationsConfig[lang][key];
        }
      });
    }

    // ==========================================
    // TEMA OSCURO/CLARO
    // ==========================================
    const themeSwitchCard = document.getElementById("themeSwitchCard");

    function aplicarTema() {
      const isDark = localStorage.getItem("theme") === "dark";
      document.body.classList.toggle("light-mode", !isDark);
      themeSwitchCard.checked = isDark;
    }

    const temaGuardado = localStorage.getItem("theme") || "dark";
    localStorage.setItem("theme", temaGuardado);
    aplicarTema();

    themeSwitchCard.addEventListener("change", () => {
      const nuevoTema = themeSwitchCard.checked ? "dark" : "light";
      localStorage.setItem("theme", nuevoTema);
      aplicarTema();
    });

    // ==========================================
    // IDIOMA
    // ==========================================
    function setLanguage(lang) {
      localStorage.setItem("lang", lang);
      aplicarIdiomaConfig();
      document.querySelectorAll(".lang-btn").forEach(btn => {
        if (btn.dataset.lang === lang) btn.classList.add("active");
        else btn.classList.remove("active");
      });
      cargarDatosUsuario(); // recargar para traducir "invitado" etc.
    }

    document.querySelectorAll(".lang-btn").forEach(btn => {
      btn.addEventListener("click", () => setLanguage(btn.dataset.lang));
    });

    const currentLang = getLang();
    document.querySelectorAll(`.lang-btn[data-lang="${currentLang}"]`).forEach(btn => btn.classList.add("active"));

    // ==========================================
    // TAMAÑO DE TEXTO
    // ==========================================
    const textSizeSelect = document.getElementById("textSizeSelect");
    function aplicarTamanioTexto() {
      const size = localStorage.getItem("fontSize") || "medium";
      textSizeSelect.value = size;
      document.body.style.fontSize = size === "small" ? "14px" : (size === "large" ? "18px" : "16px");
    }
    textSizeSelect.addEventListener("change", () => {
      localStorage.setItem("fontSize", textSizeSelect.value);
      aplicarTamanioTexto();
    });
    aplicarTamanioTexto();

    // ==========================================
    // CARGAR DATOS REALES DEL USUARIO
    // ==========================================
    async function cargarDatosUsuario() {
      try {
        const res = await fetch('obtener_sesion.php');
        const data = await res.json();
        if (data.usuario) {
          document.getElementById('displayUsername').innerHTML = `<strong>${data.usuario}</strong>`;
          document.getElementById('displayEmail').innerHTML = `<strong>${data.correo || data.cuenta || tConfig('sinCorreo')}</strong>`;
        } else {
          document.getElementById('displayUsername').innerHTML = `<strong>${tConfig('invitado')}</strong>`;
          document.getElementById('displayEmail').innerHTML = `<strong>${tConfig('sinCorreo')}</strong>`;
        }
      } catch (e) {
        console.error(e);
        document.getElementById('displayUsername').innerHTML = `<strong>${tConfig('invitado')}</strong>`;
        document.getElementById('displayEmail').innerHTML = `<strong>${tConfig('sinCorreo')}</strong>`;
      }
    }

    // ==========================================
    // MODAL CAMBIAR NOMBRE DE USUARIO
    // ==========================================
    const usernameModal = document.getElementById('usernameModal');
    const openUsernameBtn = document.getElementById('changeUsernameBtn');
    const closeUsernameBtn = document.getElementById('closeUsernameModalBtn');
    const confirmUsernameBtn = document.getElementById('confirmUsernameChangeBtn');

    function limpiarUsernameModal() {
      document.getElementById('newUsername').value = '';
    }

    openUsernameBtn.addEventListener('click', () => {
      limpiarUsernameModal();
      usernameModal.style.display = 'flex';
    });

    closeUsernameBtn.addEventListener('click', () => {
      usernameModal.style.display = 'none';
    });

    window.addEventListener('click', (e) => {
      if (e.target === usernameModal) usernameModal.style.display = 'none';
      if (e.target === passwordModal) passwordModal.style.display = 'none';
    });

    confirmUsernameBtn.addEventListener('click', async () => {
      const newUsername = document.getElementById('newUsername').value.trim();
      if (!newUsername) {
        alert(tConfig('completarCampos') || 'Completa el campo');
        return;
      }
      if (newUsername.length < 3) {
        alert('El nombre de usuario debe tener al menos 3 caracteres');
        return;
      }
      const formData = new FormData();
      formData.append('usuario', newUsername);
      try {
        const res = await fetch('cambiar_usuario.php', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.success) {
          alert(tConfig('usuarioActualizado') || 'Usuario actualizado');
          document.getElementById('displayUsername').innerHTML = `<strong>${data.usuario}</strong>`;
          usernameModal.style.display = 'none';
        } else {
          alert(tConfig('error') + ': ' + data.error);
        }
      } catch (err) {
        alert(tConfig('errorConexion') || 'Error de conexión');
      }
    });

    // ==========================================
    // MODAL CAMBIAR CONTRASEÑA
    // ==========================================
    const passwordModal = document.getElementById('passwordModal');
    const openPasswordBtn = document.getElementById('changePasswordBtn');
    const closePasswordBtn = document.getElementById('closeModalBtn');
    const confirmPassBtn = document.getElementById('confirmPassChangeBtn');

    function limpiarPasswordModal() {
      document.getElementById('currentPass').value = '';
      document.getElementById('newPass').value = '';
      document.getElementById('confirmPass').value = '';
    }

    openPasswordBtn.addEventListener('click', () => {
      limpiarPasswordModal();
      passwordModal.style.display = 'flex';
    });

    closePasswordBtn.addEventListener('click', () => {
      passwordModal.style.display = 'none';
    });

    confirmPassBtn.addEventListener('click', async () => {
      const current = document.getElementById('currentPass').value;
      const newPass = document.getElementById('newPass').value;
      const confirm = document.getElementById('confirmPass').value;
      
      if (!current || !newPass || !confirm) {
        alert(tConfig('completarCampos') || 'Completa todos los campos');
        return;
      }
      if (newPass !== confirm) {
        alert(tConfig('passNoCoinciden') || 'Las nuevas contraseñas no coinciden');
        return;
      }
      if (newPass.length < 4) {
        alert(tConfig('passCorta') || 'La nueva contraseña debe tener al menos 4 caracteres');
        return;
      }
      
      const formData = new FormData();
      formData.append('password_actual', current);
      formData.append('password_nueva', newPass);
      
      try {
        const res = await fetch('cambiar_password.php', { method: 'POST', body: formData });
        const data = await res.json();
        if (data.success) {
          alert(tConfig('passActualizada') || 'Contraseña actualizada correctamente');
          passwordModal.style.display = 'none';
        } else {
          alert(tConfig('error') + ': ' + data.error);
        }
      } catch (err) {
        alert(tConfig('errorConexion') || 'Error de conexión');
      }
    });

    // ==========================================
    // CERRAR SESIÓN
    // ==========================================
    document.getElementById('logoutBtn').addEventListener('click', () => {
      window.location.href = 'cerrar_sesion.php';
    });

    // ==========================================
    // INICIALIZAR
    // ==========================================
    aplicarIdiomaConfig();
    cargarDatosUsuario();
  </script>
</body>
