      color: var(--text);
      transition: 0.2s;
      font-weight: 600;
    }
    .lang-btn.active {
      background: var(--accent-gradient);
      color: #082016;
      border-color: transparent;
    }
    .account-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 18px;
    }
    .primary-btn, .ghost-btn {
      border-radius: 14px;
      padding: 12px 20px;
      font-weight: 700;
      cursor: pointer;
      transition: 0.2s;
    }
    .primary-btn {
      border: none;
      background: linear-gradient(180deg, var(--accent-2), var(--accent));
      color: #082016;
    }
    .ghost-btn {
      border: 1px solid rgba(118,243,194,0.16);
      background: var(--panel-soft);
      color: var(--text);
    }
    .ghost-btn:hover {
      background: rgba(118,243,194,0.1);
    }
    body.light-mode .ghost-btn {
      border-color: rgba(0,0,0,0.08);
    }
    /* MODALES */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(8px);
      display: none;
      justify-content: center;
      align-items: center;
      z-index: 10000;
    }
    .modal-content {
      background: var(--panel-strong);
      border: 1px solid var(--accent);
      border-radius: 28px;
      padding: 28px;
      width: 90%;
      max-width: 450px;
      animation: modalGlow 0.3s ease-out;
      box-shadow: 0 0 40px rgba(57, 197, 187, 0.3);
    }
    @keyframes modalGlow {
      from { opacity: 0; transform: scale(0.95); }
      to { opacity: 1; transform: scale(1); }
    }
    .modal-content h3 {
      margin: 0 0 8px;
      font-size: 26px;
      color: var(--accent);
    }
    .modal-content p {
      margin: 0 0 20px;
      color: var(--muted);
    }
    .modal-input {
      background: var(--panel-soft);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 12px 16px;
      width: 100%;
      margin: 8px 0 16px;
      color: var(--text);
      font-size: 16px;
      outline: none;
    }
    .modal-input:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 2px rgba(57,197,187,0.2);
    }
    .modal-buttons {
      display: flex;
      justify-content: flex-end;
      gap: 12px;
      margin-top: 20px;
    }
    .modal-btn {
      padding: 10px 24px;
      border-radius: 40px;
      font-weight: 700;
      cursor: pointer;
      transition: 0.2s;
    }
    .modal-btn.cancel {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text);
    }
    .modal-btn.confirm {
      background: var(--accent-gradient);
      border: none;
      color: #082016;
    }
    .modal-btn.confirm:hover, .modal-btn.cancel:hover {
      transform: translateY(-2px);
    }
  </style>
</head>
