  <script>
    // ==========================================
    // 🌐 TRADUCCIONES COMPLETAS
    // ==========================================
    const translationsConfig = {
      es: {
        inicio: "Inicio", perfil: "Perfil", mensajes: "Mensajes", notificaciones: "Notificaciones",
        configuraciones: "Configuraciones", cerrarSesion: "Cerrar sesión",
